# ─── Appwrite (Client-side — exposed to the browser) ──────────────────────────
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# ─── Appwrite (Server-side — never exposed to the browser) ────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key_with_databases_and_users_scope

# ─── Appwrite Database ────────────────────────────────────────────────────────
# The database that holds users_data, tasks, and predictions collections.
APPWRITE_DATABASE_ID=your_database_id

# ─── OpenAI (for AI-based time predictions) ───────────────────────────────────
# Requires access to gpt-4o-mini or similar chat completion model.
OPENAI_API_KEY=sk-...

# ─── Appwrite Collection IDs ──────────────────────────────────────────────────
# Create the following collections in your Appwrite database and set the IDs
# below if they differ from the defaults used in src/lib/appwrite-server.js.
#
# Collection: users_data
#   Attributes: user_id (string), motivation (integer), class_type (string),
#               created_at (string)
#
# Collection: tasks
#   Attributes: user_id (string), title (string), description (string),
#               task_type (string), class_type (string), complexity (integer),
#               motivation (integer), estimated_time (double, nullable),
#               actual_time (double, nullable), use_ai (boolean),
#               created_at (string)
#
# Collection: predictions
#   Attributes: task_id (string), user_id (string), predicted_time (double),
#               method (string), rubric_text (string), reasoning (string),
#               created_at (string)
